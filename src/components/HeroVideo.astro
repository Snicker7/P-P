---
export interface Props {
  src: string;
  webmSrc?: string;
  poster: string;
  alt?: string;
  focus?: number;
}
const { src, webmSrc, poster, alt = 'Floral design highlight reel', focus = 50 } = Astro.props;
const clamped = Math.max(0, Math.min(100, focus));
---
<div class="hero-video" style={`--focus: ${clamped}%`}>
  <video
    autoplay muted loop playsinline preload="metadata"
    poster={poster}
    aria-label={alt}
  >
    {webmSrc && <source src={webmSrc} type="video/webm" />}
    <source src={src} type="video/mp4" />
  </video>
  <img class="hero-video__poster" src={poster} alt={alt} aria-hidden="true" />
</div>

<style>
  .hero-video { position: absolute; inset: 0; overflow: hidden; }
  .hero-video video,
  .hero-video__poster {
    width: 100%; height: 100%; object-fit: cover;
    object-position: center var(--focus, 50%);
    position: absolute; inset: 0;
  }
  .hero-video__poster { display: none; }
  @media (prefers-reduced-motion: reduce) {
    .hero-video video { display: none; }
    .hero-video__poster { display: block; }
  }
</style>

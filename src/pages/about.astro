---
import Base from '~/layouts/Base.astro';
import { getEntry } from 'astro:content';
const about = await getEntry('pages', 'about');
const d = about.data;
---
<Base
  pageTitle={d.title}
  seoTitleOverride={d.seoTitle}
  seoDescriptionOverride={d.seoDescription}
>
  <article class="about">
    <div class="container">
      <p class="eyebrow">About Paper &amp; Petals</p>
    </div>

    <section class="about__section about__section--welcome container">
      <div class="about__photo">
        <img src="/images/about/about-1.jpg" alt="TaLeah, founder and floral designer of Paper & Petals" loading="lazy" />
      </div>
      <div class="about__copy">
        <h1>{d.welcomeHeading}</h1>
        {d.welcomeBody.map((p: string) => <p>{p}</p>)}
      </div>
    </section>

    <section class="about__section about__section--philosophy container">
      <div class="about__copy">
        <h2>{d.philosophyHeading}</h2>
        {d.philosophyBody.map((p: string) => <p>{p}</p>)}
      </div>
      <div class="about__photo">
        <img src="/images/about/about-2.jpg" alt="A bridal bouquet by Paper & Petals" loading="lazy" />
      </div>
    </section>

    <section class="about__cta container">
      <div class="about__photo about__photo--wide">
        <img src="/images/about/about-3.jpg" alt="TaLeah designing florals" loading="lazy" />
      </div>
      <h2>{d.ctaHeading}</h2>
      <a href="/inquire" class="btn">{d.ctaButton}</a>
    </section>
  </article>
</Base>

<style>
  .about { padding-bottom: var(--s-9); }
  .about .eyebrow { margin-top: var(--s-7); }

  .about__section {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--s-8);
    align-items: center;
    margin-top: var(--s-8);
  }
  .about__section--philosophy { grid-template-columns: 1.2fr 1fr; }

  .about__photo { aspect-ratio: 4 / 5; overflow: hidden; }
  .about__photo img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .about__copy h1 { margin-top: 0; }
  .about__copy h2 { margin-top: 0; font-size: 1.7rem; }
  .about__copy p { font-size: 1.05rem; line-height: 1.8; }
  .about__copy p + p { margin-top: var(--s-4); }

  .about__cta { text-align: center; margin-top: var(--s-9); }
  .about__cta h2 { margin: var(--s-6) 0 var(--s-5); font-size: 1.9rem; }
  .about__photo--wide {
    aspect-ratio: 16 / 9;
    max-width: 880px;
    margin: 0 auto;
  }

  @media (max-width: 820px) {
    .about__section,
    .about__section--philosophy { grid-template-columns: 1fr; gap: var(--s-5); }
    .about__photo { max-width: 480px; margin: 0 auto; }
    .about__photo--wide { aspect-ratio: 4 / 5; max-width: 480px; }
    /* Always show photo first on mobile, even when copy is first in DOM */
    .about__section--philosophy .about__photo { order: -1; }
  }
</style>

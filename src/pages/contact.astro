---
import Base from '~/layouts/Base.astro';
import { getEntry } from 'astro:content';
const settings = (await getEntry('settings', 'site')).data;
---
<Base
  pageTitle="Contact"
  seoTitleOverride="Contact — Paper & Petals Floral"
  seoDescriptionOverride="Get in touch with Paper & Petals Floral. Send a message or schedule a free wedding consultation."
>
  <section class="container section contact">
    <p class="eyebrow">Contact</p>
    <h1>Get in touch</h1>
    <p class="lead">Have a question or ready to book? Reach out by phone or email, or send a message using the form below.</p>

    <div class="contact__grid">
      <aside class="contact__info">
        <div class="contact__row">
          <p class="contact__label">Email</p>
          <p><a href={`mailto:${settings.inquiryEmail}`}>{settings.inquiryEmail}</a></p>
        </div>
        {settings.inquiryPhone && (
          <div class="contact__row">
            <p class="contact__label">Phone</p>
            <p><a href={`tel:${settings.inquiryPhone.replace(/[^0-9+]/g, '')}`}>{settings.inquiryPhone}</a></p>
          </div>
        )}
        <div class="contact__row">
          <p class="contact__label">Service area</p>
          <p>{settings.serviceArea}</p>
        </div>
        <div class="contact__row">
          <p class="contact__label">Follow along</p>
          <ul class="contact__social">
            <li><a href={`https://instagram.com/${settings.instagram}`} target="_blank" rel="noopener">Instagram</a></li>
            {settings.pinterest && <li><a href={`https://pinterest.com/${settings.pinterest}`} target="_blank" rel="noopener">Pinterest</a></li>}
            {settings.tiktok && <li><a href={`https://tiktok.com/@${settings.tiktok}`} target="_blank" rel="noopener">TikTok</a></li>}
          </ul>
        </div>
        <div class="contact__row">
          <p class="contact__label">Prefer a full inquiry?</p>
          <p><a href="/inquire" class="link">Use the wedding & event inquiry form →</a></p>
        </div>
      </aside>

      <form class="contact__form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/inquire/thanks">
        <input type="hidden" name="form-name" value="contact" />
        <p class="hp"><label>Don't fill this out: <input name="bot-field" /></label></p>

        <label>
          <span>Name</span>
          <input type="text" name="name" required autocomplete="name" />
        </label>

        <label>
          <span>Email</span>
          <input type="email" name="email" required autocomplete="email" />
        </label>

        <label>
          <span>Phone (optional)</span>
          <input type="tel" name="phone" autocomplete="tel" />
        </label>

        <label>
          <span>Subject</span>
          <select name="subject">
            <option>General question</option>
            <option>Wedding inquiry</option>
            <option>Event inquiry</option>
            <option>Press / collaboration</option>
            <option>Other</option>
          </select>
        </label>

        <label>
          <span>Message</span>
          <textarea name="message" rows="6" required></textarea>
        </label>

        <button type="submit" class="btn">Send message</button>
      </form>
    </div>
  </section>
</Base>

<style>
  .contact .lead { font-size: 1.1rem; max-width: 640px; margin-bottom: var(--s-7); }
  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: var(--s-8);
    align-items: start;
  }
  @media (max-width: 820px) { .contact__grid { grid-template-columns: 1fr; gap: var(--s-6); } }

  .contact__info { display: flex; flex-direction: column; gap: var(--s-5); }
  .contact__row p { margin: 0; }
  .contact__label {
    font-size: 0.7rem; letter-spacing: 0.32em; text-transform: uppercase;
    color: var(--accent); margin-bottom: var(--s-2) !important; font-weight: 500;
  }
  .contact__social { list-style: none; padding: 0; margin: 0; display: flex; gap: var(--s-4); flex-wrap: wrap; }
  .contact__social a { color: var(--heading); text-decoration: none; border-bottom: 1px solid var(--heading-soft); }
  .contact__social a:hover { border-bottom-color: var(--accent); color: var(--accent); }
  .link { color: var(--heading); border-bottom: 1px solid var(--heading); text-decoration: none; font-size: 0.85rem; }

  .contact__form { display: flex; flex-direction: column; gap: var(--s-4); }
  .contact__form label { display: flex; flex-direction: column; gap: var(--s-2); font-size: 0.78rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--heading); }
  .contact__form input, .contact__form select, .contact__form textarea {
    font-family: var(--font-body); font-size: 1rem; padding: var(--s-3) var(--s-4);
    border: 1px solid var(--heading-soft); background: var(--bg-soft);
    border-radius: 2px; color: var(--body);
  }
  .contact__form input:focus, .contact__form select:focus, .contact__form textarea:focus {
    outline: 2px solid var(--accent); outline-offset: 2px; border-color: var(--accent);
  }
  .contact__form textarea { resize: vertical; }
  .contact__form button { align-self: flex-start; margin-top: var(--s-3); }
  .hp { position: absolute; left: -9999px; }
</style>

---
import Base from '~/layouts/Base.astro';
import InquiryForm from '~/components/InquiryForm.astro';
import { Image } from 'astro:assets';
import { getEntry } from 'astro:content';
import ill1 from '~/assets/inquire/ill-1.jpg';
import ill2 from '~/assets/inquire/ill-2.jpg';
const page = await getEntry('pages', 'inquire');
---
<Base
  pageTitle="Inquire"
  seoTitleOverride={page.data.seoTitle}
  seoDescriptionOverride={page.data.seoDescription}
>
  <section class="container section inq-section inq-section--wedding">
    <div class="inq-section__head">
      <Image src={ill1} alt="" class="inq-section__ill" widths={[90, 180]} sizes="90px" loading="lazy" />
      <div>
        <p class="eyebrow">Inquire</p>
        <h1>{page.data.title}</h1>
      </div>
    </div>
    <p class="lead">{page.data.intro}</p>
    <InquiryForm />
  </section>

  <section class="container section inq-section inq-section--event">
    <div class="inq-section__head">
      <Image src={ill2} alt="" class="inq-section__ill" widths={[90, 180]} sizes="90px" loading="lazy" />
      <div>
        <p class="eyebrow">Event Consultation</p>
        <h2>Hosting something other than a wedding?</h2>
      </div>
    </div>
    <p class="lead">Corporate event, baby shower, birthday party — let Paper &amp; Petals design dreamy florals to elevate your next gathering. Use the form above and pick the matching event type.</p>
    <p><a href="#main" class="btn btn--ghost" onclick="document.querySelector('form[name=inquiry]')?.scrollIntoView({behavior:'smooth'}); return false;">Start an event inquiry</a></p>
  </section>
</Base>

<style>
  .lead { font-size: 1.1rem; max-width: 640px; margin-bottom: var(--s-6); }

  .inq-section { padding-top: var(--s-7); padding-bottom: var(--s-7); }
  .inq-section--event { background: var(--bg-soft); margin-top: var(--s-7); }

  .inq-section__head {
    display: flex;
    align-items: center;
    gap: var(--s-5);
    margin-bottom: var(--s-5);
  }
  .inq-section__ill {
    width: 90px;
    height: auto;
    flex: 0 0 auto;
    display: block;
  }
  .inq-section h1, .inq-section h2 { margin-top: var(--s-2); }

  @media (max-width: 480px) {
    .inq-section__ill { width: 64px; }
    .inq-section__head { gap: var(--s-4); }
  }
</style>
